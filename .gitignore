# ============================================================
# CivicProof .gitignore
# ============================================================

# Environment — never commit
.env
.env.*
.env.example
*.env

# Credentials — never commit
gcp-credentials.json
service-account-*.json
*-credentials.json
application_default_credentials.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.nuxt/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db

# Docker
docker-compose.override.yml

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform.lock.hcl
terraform.tfvars
!terraform.tfvars.example

# Pulumi
Pulumi.*.yaml
!Pulumi.dev.yaml.example

# Local data volumes
minio-data/
postgres-data/
redis-data/
opensearch-data/
kafka-data/
zookeeper-data/

# Test artifacts
test-results/
.hypothesis/

# Build artifacts
*.pyc
*.pyo
dist-info/

# Logs
logs/
*.log

# Local project data — never commit
evidence-artifacts/
case-packs/
raw-artifacts/
docs/
*.pdf
.claude/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Scripts with sensitive config — keep local only
scripts/deploy_gcp.sh

# Scratch files
test_gemini.py

# macOS
.DS_Store
.AppleDouble
.LSOverride
user_manual.pdf
user_manual.md
